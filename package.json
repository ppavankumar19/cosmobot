{
  "name": "cosmobot",
  "version": "1.0.0",
  "description": "Space exploration chatbot powered by Groq + LLaMA 3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cp node_modules/three/build/three.module.min.js public/three.module.min.js && cp node_modules/three/build/three.core.min.js public/three.core.js",
